# ============================================================
# Mission Control - Environment Configuration
# ============================================================
# Copy this to .env and fill in your values
# ============================================================

# --- LLM Authentication (Claude Code subscription) ---
# Requires a Claude Pro/Max subscription.
# Run: claude auth login
# Then copy the token, or run: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# --- Database ---
# Option A: PostgreSQL (recommended)
POSTGRES_USER=missionctl
POSTGRES_PASSWORD=missionctl
POSTGRES_DB=missioncontrol

# Option B: SQLite (zero-config local dev)
# USE_SQLITE=true
# SQLITE_PATH=data/mission_control.db

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=  # comma-separated Telegram user IDs
TELEGRAM_NOTIFICATION_CHAT_ID=  # optional, falls back to first allowed user
NOTIFICATION_TIMEZONE=UTC  # e.g. "Asia/Kolkata", "America/New_York"

# --- Service Ports ---
API_PORT=8000
DASHBOARD_PORT=3000
DB_PORT=5432

# --- Agent Defaults ---
DEFAULT_MODEL=claude-haiku-4-5
SMART_MODEL=claude-sonnet-4-6
CHAT_MODEL=claude-sonnet-4-6
MAX_AGENT_BUDGET_USD=0.50

# --- Voice (optional) ---
# OPENAI_API_KEY=  # for Whisper voice transcription

# --- Identity ---
BOT_NAME=MC
IDENTITY_FILE=workspace/identity.md
