# ============================================================
# Mission Control - Environment Configuration
# ============================================================
# Copy this to .env and fill in your values
# ============================================================

# --- LLM Authentication (choose one) ---

# Option A: Anthropic API Key (recommended - stable, no expiry)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Option B: Claude Subscription OAuth Token (Pro/Max)
# Run: claude setup-token
# Note: Token expires every few hours, may need refresh
# CLAUDE_CODE_OAUTH_TOKEN=

# Option C: Alternative providers (OpenRouter, Ollama, etc.)
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# --- Database ---
POSTGRES_USER=missionctl
POSTGRES_PASSWORD=missionctl
POSTGRES_DB=missioncontrol

# --- Telegram Bot (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=  # comma-separated Telegram user IDs

# --- Service Ports ---
API_PORT=8000
DASHBOARD_PORT=3000
DB_PORT=5432
REDIS_PORT=6379

# --- Agent Defaults ---
DEFAULT_MODEL=claude-haiku-4-5
SMART_MODEL=claude-sonnet-4-6
MAX_AGENT_BUDGET_USD=0.50
AGENT_WORKDIR=/app/workdir
